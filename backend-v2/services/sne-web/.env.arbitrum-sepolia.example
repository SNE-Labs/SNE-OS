DEFAULT_NETWORK=arbitrum-sepolia
SNE_KEYS_NETWORK=arbitrum-sepolia

ARBITRUM_SEPOLIA_RPC_URLS=https://sepolia-rollup.arbitrum.io/rpc,https://arbitrum-sepolia-rpc.publicnode.com

# Point directly to the deployment manifest generated by PR 1
