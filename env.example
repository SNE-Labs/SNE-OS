# SNE OS Environment Variables

# API Configuration
VITE_API_BASE=https://snelabs.space

# WalletConnect
VITE_WALLETCONNECT_PROJECT_ID=3fcc6bba6f1de962d911bb5b5c3dba68

# EVM Networks
VITE_ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia-rpc.publicnode.com
VITE_ARBITRUM_RPC_URL=https://arbitrum-one-rpc.publicnode.com
VITE_SCROLL_RPC_URL=https://scroll-rpc.publicnode.com

# Tron checkout rail
VITE_TRON_RPC_URL=https://api.trongrid.io

# SIWE (Sign-In with Ethereum)
VITE_SIWE_DOMAIN=snelabs.space
VITE_SIWE_ORIGIN=https://snelabs.space
VITE_SIWE_CHAIN_ID=42161

# Development (uncomment for local development)
# VITE_API_BASE=http://localhost:5000

# Intel institutional and distribution
# INTEL_INSTITUTIONAL_SECRET=change-me
# INTEL_DISTRIBUTION_SECRET=change-me
# INTEL_INSTITUTIONAL_PROVIDER=openai
# INTEL_INSTITUTIONAL_MODEL=gpt-5.4-mini
# INTEL_DISTRIBUTION_MODEL=gpt-5.4-mini
# INTEL_TELEGRAM_AUTO_PUBLISH=true
# INTEL_TELEGRAM_AUTO_MIN_INTERVAL_SECONDS=720
# INTEL_TELEGRAM_AUTO_HOURLY_LIMIT=4
# INTEL_X_AUTO_PUBLISH=true
# INTEL_X_AUTO_MIN_INTERVAL_SECONDS=1800
# INTEL_X_AUTO_HOURLY_LIMIT=2
# INTEL_X_NATIVE_FORMATS_ENABLED=true
# INTEL_DISTRIBUTION_DEDUPE_ENABLED=true
# INTEL_DISTRIBUTION_DEDUPE_SECONDS=43200
# RADAR_REPORT_SECRET=

# Telegram publishing
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# WhatsApp Cloud API publishing
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_TO=

# X publishing via outbound webhook
# X_PUBLISH_WEBHOOK_URL=
# X_PUBLISH_WEBHOOK_TOKEN=

# X official API publishing (preferred: OAuth 1.0a for a single SNELabs account)
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# X OAuth 2.0 user-context publishing fallback
# X_AUTH_MODE=oauth2
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_OAUTH2_ACCESS_TOKEN=
# X_OAUTH2_REFRESH_TOKEN=
# X_TOKEN_TYPE=Bearer
# X_TOKEN_SCOPE=tweet.read tweet.write users.read offline.access

# Threads API publishing
